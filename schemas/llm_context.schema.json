{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM match context",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "home_team": {
      "type": "string",
      "minLength": 1
    },
    "away_team": {
      "type": "string",
      "minLength": 1
    },
    "home_absence_severity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "away_absence_severity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "home_lineup_uncertainty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "away_lineup_uncertainty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "home_rotation_risk": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "away_rotation_risk": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "home_tactical_edge": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "away_tactical_edge": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "llm_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "source_quality": {
      "type": "string",
      "enum": ["none", "thin", "mixed", "good", "official"]
    }
  },
  "required": [
    "date",
    "home_team",
    "away_team",
    "home_absence_severity",
    "away_absence_severity",
    "home_lineup_uncertainty",
    "away_lineup_uncertainty",
    "home_rotation_risk",
    "away_rotation_risk",
    "home_tactical_edge",
    "away_tactical_edge",
    "llm_confidence",
    "evidence_summary",
    "source_quality"
  ]
}
